{
  "mcpServers": {
{{#if mcps.google}}
    "google_workspace": {
      "command": "uvx",
      "args": ["workspace-mcp"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "{{env.GOOGLE_OAUTH_CLIENT_ID}}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "{{env.GOOGLE_OAUTH_CLIENT_SECRET}}"
      }
    }{{#if (or mcps.obsidian mcps.exa mcps.gitnexus mcps.apify mcps.n8n)}},{{/if}}
{{/if}}
{{#if mcps.obsidian}}
    "obsidian": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{{vaultPath}}"]
    }{{#if (or mcps.exa mcps.gitnexus mcps.apify mcps.n8n)}},{{/if}}
{{/if}}
{{#if mcps.exa}}
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": { "EXA_API_KEY": "{{env.EXA_API_KEY}}" }
    }{{#if (or mcps.gitnexus mcps.apify mcps.n8n)}},{{/if}}
{{/if}}
{{#if mcps.gitnexus}}
    "gitnexus": {
      "command": "npx",
      "args": ["-y", "gitnexus-mcp"]
    }{{#if (or mcps.apify mcps.n8n)}},{{/if}}
{{/if}}
{{#if mcps.apify}}
    "apify": {
      "command": "npx",
      "args": ["-y", "@apify/actors-mcp-server"],
      "env": { "APIFY_TOKEN": "{{env.APIFY_TOKEN}}" }
    }{{#if mcps.n8n}},{{/if}}
{{/if}}
{{#if mcps.n8n}}
    "n8n": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "N8N_API_URL": "{{env.N8N_API_URL}}",
        "N8N_API_KEY": "{{env.N8N_API_KEY}}"
      }
    }
{{/if}}
  }
}
