{
  "mcpServers": {
{{#if mcps.google}}
    "google_workspace": {
      "command": "uvx",
      "args": ["workspace-mcp"],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "{{env.GOOGLE_OAUTH_CLIENT_ID}}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "{{env.GOOGLE_OAUTH_CLIENT_SECRET}}"
      }
    }{{#if (or mcps.obsidian mcps.tavily mcps.exa mcps.firecrawl)}},{{/if}}
{{/if}}
{{#if mcps.obsidian}}
    "obsidian": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{{vaultPath}}"]
    }{{#if (or mcps.tavily mcps.exa mcps.firecrawl)}},{{/if}}
{{/if}}
{{#if mcps.tavily}}
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": { "TAVILY_API_KEY": "{{env.TAVILY_API_KEY}}" }
    }{{#if (or mcps.exa mcps.firecrawl)}},{{/if}}
{{/if}}
{{#if mcps.exa}}
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": { "EXA_API_KEY": "{{env.EXA_API_KEY}}" }
    }{{#if mcps.firecrawl}},{{/if}}
{{/if}}
{{#if mcps.firecrawl}}
    "firecrawl": {
      "command": "npx",
      "args": ["-y", "firecrawl-mcp"],
      "env": { "FIRECRAWL_API_KEY": "{{env.FIRECRAWL_API_KEY}}" }
    }
{{/if}}
  }
}
