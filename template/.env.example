# nello-claw .env - all keys in one place
# After editing, run: bash scripts/sync-env-to-configs.sh

# ============================================================
# Required
# ============================================================

# Telegram bot (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (get from /chatid command after bot starts)
ALLOWED_CHAT_ID=

# ============================================================
# Voice (optional)
# ============================================================

# Groq (free tier, speech-to-text via Whisper)
GROQ_API_KEY=

# ============================================================
# Optional MCPs
# ============================================================

# Google Workspace OAuth (Gmail, Drive, Docs, Sheets, Calendar)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_USER_EMAIL=

# OpenAI (optional, for GPT-4o-mini note extraction)
OPENAI_API_KEY=

# Tavily (research skill)
TAVILY_API_KEY=

# Exa (research skill)
EXA_API_KEY=

# Firecrawl (research skill + scraping)
FIRECRAWL_API_KEY=

# Apify (optional, web scraping marketplace)
APIFY_TOKEN=

# n8n (optional, only if you use n8n)
N8N_API_URL=
N8N_API_KEY=

# ============================================================
# System
# ============================================================

NODE_ENV=production
LOG_LEVEL=info
